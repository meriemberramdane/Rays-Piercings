# Copie ce fichier en ".env" à la racine du projet et remplis les valeurs
# trouvées dans ton dashboard Supabase : Project Settings > API Keys.

# URL du projet, ex: https://xxxxxxxxxxxx.supabase.co
VITE_SUPABASE_URL=

# Clé publique côté client (jamais la clé "service_role"/"secret").
# Nouveau dashboard : "Publishable key" (sb_publishable_...)
# Ancien dashboard : clé "anon public"
VITE_SUPABASE_ANON_KEY=

# Mot de passe pour accéder à l'espace admin du site (libre, choisis-en un fort).
VITE_ADMIN_PASSWORD=
